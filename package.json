{
  "name": "localforge-studio",
  "version": "1.0.0",
  "description": "Suite desktop per la gestione e il trasferimento di file",
  "author": "Pedro",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "build:standalone": "next build && node build-slim/prepare-standalone.js",
    "start": "cross-env NODE_ENV=production node server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "electron:dev": "electron .",
    "electron:build": "npm run build:standalone && electron-builder --win --publish never",
    "electron:build:publish": "npm run build:standalone && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.localforge.studio",
    "productName": "LocalForge Studio",
    "copyright": "Copyright © 2024 LocalForge Studio",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-notifier/vendor/**",
      "**/*.node"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "!.next/cache/**",
      "public/**/*",
      "server.js",
      "next.config.ts",
      "package.json",
      "node_modules/**/*",

      "!node_modules/.cache",
      "!node_modules/next/**",
      "!node_modules/electron-builder",
      "!node_modules/electron",
      "!src",

      "!node_modules/app-builder-bin/**",
      "!node_modules/app-builder-lib/**",
      "!node_modules/electron-winstaller/**",
      "!node_modules/7zip-bin/**",
      "!node_modules/builder-util/**",
      "!node_modules/dmg-builder/**",
      "!node_modules/electron-publish/**",

      "!node_modules/@next/swc-*/**",
      "!node_modules/@next/.swc-*/**",

      "!.next/trace",
      "!.next/**/*.nft.json",

      "!node_modules/next/dist/build/**",
      "!node_modules/next/dist/cli/**",
      "!node_modules/next/dist/export/**",
      "!node_modules/next/dist/telemetry/**",
      "!node_modules/next/dist/compiled/next-devtools/**",
      "!node_modules/next/dist/compiled/@vercel/**",

      "!node_modules/next/dist/esm/**",
      "!node_modules/next/dist/compiled/webpack/**",
      "!node_modules/next/dist/compiled/babel/**",
      "!node_modules/next/dist/compiled/@babel/**",
      "!node_modules/next/dist/compiled/babel-code-frame/**",
      "!node_modules/next/dist/compiled/babel-packages/**",
      "!node_modules/next/dist/compiled/terser/**",
      "!node_modules/next/dist/compiled/amphtml-validator/**",
      "!node_modules/next/dist/compiled/@ampproject/**",
      "!node_modules/next/dist/compiled/browserslist/**",
      "!node_modules/next/dist/compiled/jest-worker/**",
      "!node_modules/next/dist/compiled/react-dom-experimental/**",
      "!node_modules/next/dist/compiled/react-experimental/**",
      "!node_modules/next/dist/compiled/react-server-dom-turbopack/**",
      "!node_modules/next/dist/compiled/react-server-dom-turbopack-experimental/**",
      "!node_modules/next/dist/compiled/react-server-dom-webpack-experimental/**",
      "!node_modules/next/dist/compiled/scheduler-experimental/**",
      "!node_modules/next/dist/compiled/postcss-preset-env/**",
      "!node_modules/next/dist/compiled/cssnano-simple/**",
      "!node_modules/next/dist/compiled/sass-loader/**",
      "!node_modules/next/dist/compiled/source-map/**",
      "!node_modules/next/dist/compiled/source-map08/**",
      "!node_modules/next/dist/compiled/watchpack/**",
      "!node_modules/next/dist/compiled/css-loader/**",
      "!node_modules/next/dist/compiled/mini-css-extract-plugin/**",
      "!node_modules/next/dist/compiled/loader-runner/**",
      "!node_modules/next/dist/compiled/schema-utils2/**",
      "!node_modules/next/dist/compiled/schema-utils3/**",
      "!node_modules/next/dist/compiled/gzip-size/**",
      "!node_modules/next/dist/compiled/text-table/**",
      "!node_modules/next/dist/compiled/@mswjs/**",
      "!node_modules/next/dist/compiled/cli-select/**",
      "!node_modules/next/dist/compiled/commander/**",
      "!node_modules/next/dist/compiled/comment-json/**",

      "!node_modules/typescript/**",
      "!node_modules/@esbuild/**",
      "!node_modules/esbuild/**",
      "!node_modules/tailwindcss/**",
      "!node_modules/postcss/**",
      "!node_modules/autoprefixer/**",
      "!node_modules/@rollup/**",
      "!node_modules/rollup/**",

      "!node_modules/@imgly/**",
      "!node_modules/onnxruntime-web/**",
      "!node_modules/@napi-rs/**",
      "!node_modules/@img/**",
      "!node_modules/pdfjs-dist/**",
      "!node_modules/pdf-lib/**",
      "!node_modules/lucide-react/**",
      "!node_modules/@radix-ui/**",
      "!node_modules/date-fns/**",
      "!node_modules/date-fns-jalali/**",
      "!node_modules/react-day-picker/**",
      "!node_modules/recharts/**",
      "!node_modules/d3-array/**",
      "!node_modules/d3-color/**",
      "!node_modules/d3-ease/**",
      "!node_modules/d3-format/**",
      "!node_modules/d3-interpolate/**",
      "!node_modules/d3-path/**",
      "!node_modules/d3-scale/**",
      "!node_modules/d3-shape/**",
      "!node_modules/d3-time/**",
      "!node_modules/d3-time-format/**",
      "!node_modules/embla-carousel-react/**",
      "!node_modules/embla-carousel/**",
      "!node_modules/react-hook-form/**",
      "!node_modules/@hookform/**",
      "!node_modules/clsx/**",
      "!node_modules/class-variance-authority/**",
      "!node_modules/tailwind-merge/**",
      "!node_modules/tailwindcss-animate/**",
      "!node_modules/heic2any/**",
      "!node_modules/jsbarcode/**",
      "!node_modules/patch-package/**",
      "!node_modules/zod/**",
      "!node_modules/@vitejs/**",

      "!node_modules/**/*.map",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/.github/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/README*",
      "!node_modules/**/*.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LocalForge Studio",
      "installerHeaderIcon": "public/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "TUO_USERNAME_GITHUB",
      "repo": "fileforge"
    }
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "dotenv": "^16.5.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "next": "^15.5.14",
    "node-notifier": "^10.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "selfsigned": "^2.4.1",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@imgly/background-removal": "^1.7.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^3.6.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "heic2any": "^0.0.4",
    "ip": "^1.1.9",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.475.0",
    "patch-package": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "postcss": "^8",
    "react-day-picker": "^9.11.3",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "wait-on": "^9.0.4",
    "zod": "^3.24.2"
  }
}
