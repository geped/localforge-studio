{
  "name": "localforge-studio",
  "version": "1.0.0",
  "description": "Suite desktop per la gestione e il trasferimento di file",
  "author": "Pedro",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "start": "cross-env NODE_ENV=production node server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "electron:dev": "electron .",
    "electron:build": "next build && electron-builder --win --publish never",
    "electron:build:publish": "next build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.localforge.studio",
    "productName": "LocalForge Studio",
    "copyright": "Copyright © 2024 LocalForge Studio",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "server.js",
      "next.config.ts",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/electron-builder",
      "!node_modules/electron",
      "!src"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LocalForge Studio",
      "installerHeaderIcon": "public/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "TUO_USERNAME_GITHUB",
      "repo": "fileforge"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@imgly/background-removal": "^1.7.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "archiver": "^7.0.1",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.18.2",
    "heic2any": "^0.0.4",
    "ip": "^1.1.9",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.475.0",
    "multer": "^1.4.5-lts.1",
    "next": "^15.5.14",
    "node-notifier": "^10.0.1",
    "patch-package": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "selfsigned": "^2.4.1",
    "socket.io": "^4.7.4",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "wait-on": "^9.0.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
